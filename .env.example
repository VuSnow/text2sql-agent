# MCP Server
MCP_SERVER_URL=http://localhost:8000

# LLM Provider: openai
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your-openai-api-key-here
LLM_TEMPERATURE=0.0

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# RAG
RAG_TOP_K=5

# Agent behavior
MAX_REPAIR_ATTEMPTS=3
DEFAULT_EXECUTE=false

# Schema scope (comma-separated, empty = all tables from MCP)
TABLE_ALLOWLIST=
SCHEMA_NAME=public

# Logging
LOG_LEVEL=INFO
